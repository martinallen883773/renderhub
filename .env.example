# ===============================================
# LastMailer - Render.com Environment Variables
# ===============================================

# قاعدة البيانات PostgreSQL (على Render يتم ملؤها تلقائياً من قاعدة البيانات)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# مفتاح OpenAI للذكاء الاصطناعي (Generate / Change message)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# (اختياري) لو بتستخدم مزود متوافق مع OpenAI
# OPENAI_BASE_URL=https://api.openai.com/v1

# سر تشفير الجلسات (أي نص طويل عشوائي)
SESSION_SECRET=change-me-to-a-long-random-string

# مفتاح ja.cat لاختصار الروابط
JACAT_API_KEY=d99746961595b0a70eb2304c30d2fe

# المنفذ (Render يحدده تلقائياً - لا تغيّره)
# PORT=5000
NODE_ENV=production
